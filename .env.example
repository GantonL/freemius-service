# Server
PORT=8000

# Freemius API credentials
# Find these in your Freemius Developer Dashboard -> Plugins -> Keys
FREEMIUS_STORE_ID=
FREEMIUS_PUBLIC_KEY=
FREEMIUS_SECRET_KEY=

# Freemius Webhooks
# Generate a random secret and save it here. Set the same value in your
# Freemius dashboard under: Developer -> Webhooks -> Secret
FREEMIUS_WEBHOOK_SECRET=

# Optional: Forward verified webhook events to your app
# Leave empty to disable forwarding
WEBHOOK_FORWARD_URL=
WEBHOOK_FORWARD_SECRET=
